{
  "name": "worktrips-doc-backend",
  "version": "1.0.0",
  "description": "worktrips.doc — Document Management System Backend",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@azure/identity": "^4.4.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/storage-blob": "^12.23.0",
    "applicationinsights": "^3.3.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.4",
    "pg": "^8.13.0",
    "pg-format": "^1.0.4",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-azure-application-insights": "^4.0.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
